# Copy to .env (which is gitignored) and fill in real values.
# The router accepts either spelling of the OpenAI key; pick whichever
# is already in your shell.

OPEN_AI_API_KEY=sk-your-openai-key-here
# OPENAI_API_KEY=sk-your-openai-key-here     # same thing, either spelling works

# Optional — override cloud endpoint/model (defaults: OpenAI, gpt-5.5)
# CLOUD_BASE=https://api.openai.com/v1
# CLOUD_MODEL=gpt-5.5

# Optional — override local endpoint/model (defaults: Ollama on localhost)
# LOCAL_BASE=http://127.0.0.1:11434/v1
# LOCAL_MODEL=gemma4:31b

# Optional — local-call guards (v1.4.1). Defaults are safe; override
# only if benchmarking a model with weird generation behaviour.
# ROUTER_LOCAL_NUM_PREDICT_CAP=4096          # cap Ollama num_predict per call (-1 disables)
# ROUTER_LOCAL_REQUEST_TIMEOUT_MS=180000     # 3-minute hard wall-clock per local call
# ROUTER_LOCAL_REPEAT_PENALTY=1.1            # override weak model defaults (e.g. qwen3-coder ships 1.05)
